{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "SSL writes / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(clawguard_ssl_writes_total[1m])) by (hook, truncated)",
          "legendFormat": "{{hook}} truncated={{truncated}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Captured bytes / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(clawguard_ssl_write_bytes_total[1m]))",
          "legendFormat": "bytes/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Attached targets",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "clawguard_attached_targets",
          "legendFormat": "targets",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reassembly timeouts (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "clawguard_reassembly_timeouts_total",
          "legendFormat": "timeouts",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Attach errors (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "clawguard_attach_errors_total",
          "legendFormat": "errors",
          "refId": "A"
        }
      ]
    },
    {
      "title": "SSL writes total (by hook)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (hook) (clawguard_ssl_writes_total)",
          "legendFormat": "{{hook}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reassembly timeouts / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 1 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(clawguard_reassembly_timeouts_total[5m])) * 60",
          "legendFormat": "timeouts/min",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["clawguard", "ebpf", "tls", "ai-observability"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ClawGuard — TLS Plaintext Auditor",
  "uid": "clawguard-tls",
  "version": 1
}
